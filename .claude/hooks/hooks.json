{
  "version": "1.0",
  "rules": [
    {
      "name": "dangerous-commands",
      "enabled": true,
      "patterns": [
        "rm -rf",
        "> /dev/sda",
        "mkfs.*",
        ":(){ :|:& };:"
      ],
      "action": "block"
    },
    {
      "name": "audit",
      "enabled": true,
      "events": ["file_write", "bash_execution"],
      "action": "log"
    }
  ]
}
